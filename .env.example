# =============================================================================
# Configuration for the Qwen OpenAI-compatible LLM platform.
# Copy to `.env` and edit. `docker compose` reads this file automatically.
#
#   cp .env.example .env
#   # then set GATEWAY_API_KEYS and (recommended) ENGINE_API_KEY + ADMIN_API_KEY
# =============================================================================

# -----------------------------------------------------------------------------
# GATEWAY — server
# -----------------------------------------------------------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_WORKERS=1          # keep 1: rate-limit/analytics state is per-process
LOG_LEVEL=INFO
LOG_JSON=true             # JSON logs for prod; set false for readable local logs
ENVIRONMENT=production
SERVICE_NAME=qwen-gateway

# -----------------------------------------------------------------------------
# GATEWAY — authentication  (THESE ARE THE KEYS YOU PASTE INTO ZOO CODE)
# Generate strong keys, e.g.:  openssl rand -hex 24   ->  prefix with sk-
# Comma-separate to issue multiple keys (per user/machine) for per-key analytics.
# -----------------------------------------------------------------------------
GATEWAY_API_KEYS=sk-CHANGE-ME-please-generate-a-real-key
REQUIRE_AUTH=true
# Separate key that unlocks /admin/* analytics endpoints (leave blank to disable).
ADMIN_API_KEY=admin-CHANGE-ME

# -----------------------------------------------------------------------------
# GATEWAY — upstream engine
# In docker-compose both engine profiles answer to the "engine" alias.
# For the RunPod all-in-one image the engine is local: http://127.0.0.1:8001/v1
# -----------------------------------------------------------------------------
UPSTREAM_BASE_URL=http://engine:8001/v1
# Shared secret between gateway and engine (must equal ENGINE_API_KEY below).
UPSTREAM_API_KEY=engine-internal-secret
REQUEST_TIMEOUT_SECONDS=600
STREAM_IDLE_TIMEOUT=120
UPSTREAM_CONNECT_TIMEOUT=10
UPSTREAM_MAX_CONNECTIONS=100

# -----------------------------------------------------------------------------
# GATEWAY — model routing
# DEFAULT_MODEL is what Zoo Code should put in its "Model" field.
# MODEL_ALIASES optionally maps public ids -> the engine's served id (JSON), e.g.
#   MODEL_ALIASES={"qwen3.6-35b-a3b":"qwen3.6-35b-a3b","coder":"qwen3.6-35b-a3b"}
# -----------------------------------------------------------------------------
DEFAULT_MODEL=qwen3.6-35b-a3b
MODEL_ALIASES=
ALLOW_UNLISTED_MODELS=false

# -----------------------------------------------------------------------------
# GATEWAY — rate limiting (per API key; 0 disables a given limit)
# -----------------------------------------------------------------------------
RATE_LIMIT_RPM=120
RATE_LIMIT_TPM=200000
RATE_LIMIT_CONCURRENCY=8

# -----------------------------------------------------------------------------
# GATEWAY — analytics / usage tracking / request history
# -----------------------------------------------------------------------------
ANALYTICS_ENABLED=true
DATABASE_URL=sqlite+aiosqlite:///./data/gateway.db
ANALYTICS_REDACT_CONTENT=true     # store only metadata + token counts, not text
CAPTURE_STREAM_USAGE=true         # inject stream_options.include_usage for usage
CORS_ORIGINS=*
MAX_REQUEST_BYTES=20971520        # 20 MiB

# =============================================================================
# ENGINE — shared
# =============================================================================
SERVED_MODEL_NAME=qwen3.6-35b-a3b   # MUST match DEFAULT_MODEL above
ENGINE_PORT=8001
# Must equal UPSTREAM_API_KEY so the gateway can authenticate to the engine.
ENGINE_API_KEY=engine-internal-secret

# Model source (downloaded at runtime to the persistent volume, NOT baked in).
HF_REPO=unsloth/Qwen3.6-35B-A3B-GGUF
HF_FILE=Qwen3.6-35B-A3B-UD-IQ4_NL_XL.gguf
MODEL_DIR=/models
# HF_TOKEN=                          # only for gated/private repos
# MODEL_DOWNLOAD_URL=                # full URL override (optional)

# =============================================================================
# ENGINE — llama.cpp (DEFAULT profile)
# Effective per-request context = CTX_SIZE / PARALLEL_SLOTS.
# Defaults: ONE request with the full 128K context, q8_0 KV cache to fit it on
# a 48GB A6000. Pair with Zoo Code's context condensing for long sessions.
# =============================================================================
N_GPU_LAYERS=999          # offload all layers to GPU
CTX_SIZE=131072           # TOTAL KV-cache context (128K). Model supports 262K native.
PARALLEL_SLOTS=1          # 1 = the whole context goes to a single request
BATCH_SIZE=2048
UBATCH_SIZE=512
FLASH_ATTN=on             # required for quantized KV cache below
THREADS=8
REASONING_FORMAT=auto     # extract <think> blocks into reasoning_content
# Default sampling (Qwen thinking/coding preset). Applied only when a request
# omits the parameter, so a client's own temperature/top_p still takes priority.
SAMPLING_TEMP=0.6
SAMPLING_TOP_P=0.95
SAMPLING_TOP_K=20
SAMPLING_MIN_P=0.0
SAMPLING_PRESENCE_PENALTY=0.0
# KV cache stored q8_0 (near-lossless) to fit 128K comfortably / reach toward 256K.
# Set both to f16 for max quality if you have VRAM headroom, or remove to default f16.
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0
# CHAT_TEMPLATE_FILE=/models/chat_template.jinja   # override template if needed
# EXTRA_LLAMA_ARGS=

# =============================================================================
# ENGINE — vLLM (ALTERNATIVE profile; serves an AWQ quant, NOT the GGUF)
# =============================================================================
VLLM_MODEL=QuantTrio/Qwen3.6-35B-A3B-AWQ
VLLM_QUANTIZATION=awq_marlin
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=16
# KV_CACHE_DTYPE=fp8       # stretch context further on the AWQ path
TOOL_CALL_PARSER=qwen3_coder   # per the official model card (native XML tool format)
REASONING_PARSER=qwen3
# vLLM >= 0.19.0 recommended by the model card for Qwen3.6 support.
# EXTRA_VLLM_ARGS=
